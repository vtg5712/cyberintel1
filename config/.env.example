# ─── CyberIntel Platform — Configuration ────────────────────
# Copy this to .env and adjust for your environment

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=investigation_secret

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Anonymization
# Options: direct | proxy_chain | tor | custom
ANONYMIZATION_MODE=direct
TOR_PROXY=socks5://tor:9050
CUSTOM_PROXY=
RATE_LIMIT_RPS=2.0
SAFE_CRAWL_MODE=true

# Crawler
SCREENSHOT_DIR=/app/screenshots
CRAWLER_TIMEOUT=30000
MAX_CRAWL_DEPTH=2

# Campaign Detection
SIMILARITY_THRESHOLD=0.75
CAMPAIGN_TIME_WINDOW_DAYS=30
